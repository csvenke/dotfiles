{
  "$schema": "https://opencode.ai/config.json",
  "theme": "nordic",
  "plugin": ["opencode-gemini-auth"],
  "permission": {
    "external_directory": "allow"
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright-test": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "playwright", "run-test-mcp-server"]
    }
  }
}
