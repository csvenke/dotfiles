{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth"],
  "permission": {
    "external_directory": "allow"
  },
  "autoupdate": false,
  "lsp": {
    "csharp": {
      "disabled": true
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "mempalace": {
      "enabled": true,
      "type": "local",
      "command": ["mempalace-mcp"]
    }
  }
}
