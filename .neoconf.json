{
  "neodev": {
    "library": {
      "enabled": true,
      "plugins": ["neoconf.nvim", "nvim-lspconfig"]
    }
  },
  "neoconf": {
    "plugins": {
      "lua_ls": {
        "enabled": true
      }
    }
  },
  "lspconfig": {
    "lua_ls": {
      "Lua.runtime.version": "LuaJIT",
      "Lua.completion.callSnippet": "Replace",
      "Lua.workspace.checkThirdParty": false
    },
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (\"git+file://\" + toString ./.)).inputs.nixpkgs { }"
      }
    }
  }
}
